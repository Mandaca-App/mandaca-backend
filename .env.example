# ─── Banco de dados local (Docker) ──────────────────────────
POSTGRES_USER=meuprojeto
POSTGRES_PASSWORD=suasenha
POSTGRES_DB=meuprojeto_db

# DATABASE_URL usada pela app e pelo Alembic
# Local  → aponta para o container Docker
# Nuvem  → substitua pela connection string do Supabase
DATABASE_URL=postgresql://meuprojeto:suasenha@localhost:5432/meuprojeto_db

# ─── Supabase (nuvem) ────────────────────────────────────────
# Cole a connection string do Supabase quando for fazer deploy
# Exemplo: postgresql://postgres:senha@db.xxxx.supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres:senha@db.xxxx.supabase.co:5432/postgres

# ─── Aplicação ───────────────────────────────────────────────
APP_ENV=development       # development | production
SECRET_KEY=troque-por-uma-chave-secreta-longa
APP_DEBUG=true
