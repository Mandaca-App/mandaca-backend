# ─── Banco de dados ──────────────────────────────────────────
# Opção 1: Supabase (nuvem) — padrão para desenvolvimento e produção
POSTGRES_USER=postgres.<seu-project-ref>
POSTGRES_PASSWORD=sua-senha-supabase
POSTGRES_DB=mandacadb_prod
DATABASE_URL=postgresql://postgres.<seu-project-ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres

# Opção 2: Docker (local) — descomente e comente as linhas da Opção 1
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=sua-senha-local
# POSTGRES_DB=mandaca_dev
# DATABASE_URL=postgresql+psycopg://postgres:<senha>@localhost:5432/mandaca_dev

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://<seu-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# ─── Groq ────────────────────────────────────────────────────
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_sua-chave-groq-aqui

# ─── Aplicação ───────────────────────────────────────────────
APP_ENV=development       # development | production
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
APP_DEBUG=true

# ─── Google Maps Geocoding ───────────────────────────────────
# Obtenha em: https://console.cloud.google.com -> APIs e Servicos -> Credenciais
# Habilite: "Geocoding API" no projeto do Google Cloud
GOOGLE_MAPS_API_KEY=AIza_sua-chave-aqui
